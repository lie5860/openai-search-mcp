# OpenAI Search MCP 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置

# OpenAI 兼容的 API 端点
# 例如: https://api.openai.com/v1 或其他兼容端点
OPENAI_API_URL=https://api.openai.com/v1

# 你的 API 密钥
OPENAI_API_KEY=your-api-key-here

# 模型标识符（可选，默认: gpt-4o）
OPENAI_MODEL=gpt-4o

# 调试模式（可选，默认: false）
DEBUG=false

# 日志级别（可选，默认: INFO）
# 可选值: DEBUG, INFO, WARN, ERROR
OPENAI_LOG_LEVEL=INFO

# ---------- web_fetch 默认引擎 ----------
# 未传 fetch_engine 时，服务端使用此值；也影响 npm run test-server 的 fetch 测试（默认 llm）
# FETCH_ENGINE=llm
# FETCH_ENGINE=tavily
# FETCH_ENGINE=firecrawl

# Tavily Extract API（fetch_engine=tavily 时使用）
# TAVILY_API_URL=https://api.tavily.com
# TAVILY_API_KEY=tvly-your-tavily-key

# Firecrawl Scrape API（fetch_engine=firecrawl 时使用）
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v2
# FIRECRAWL_API_KEY=your-firecrawl-api-key
